{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)8b6f68eb-526d-4014-846e-0d34257d4746","ParentGuid":"(Guid)552aeba8-69d4-4f40-9593-59848768ad16","Name":"(string)M_ExtractTargetLimitsFromTuple","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\nM_ExtractTargetLimitsFromTuple := FALSE;\nq_uiSize    := 0;\nq_sLimitMin := '';\nq_sLimitMax := '';\nsWorkingString := i_sDataToParse;\n\n// Remove surrounding whitespace in-place\nStrTrimStartA(ADR(sWorkingString));\nStrTrimEndA(ADR(sWorkingString));\n\n// Need at least '[' and ']' (2 chars)\niStringLength := DINT_TO_INT(StrLenA(ADR(sWorkingString)));\nIF iStringLength < 2 THEN\n    RETURN;\nEND_IF;\n\n// First character must be '[' (position 1)\nIF StrFindA(ADR(sWorkingString), ADR(sOpenBracket), 1) <> 1 THEN\n    RETURN;\nEND_IF;\n\n// Last character must be ']' (search from position iStringLength → only matches there)\nIF StrFindA(ADR(sWorkingString), ADR(sCloseBracket), INT_TO_UINT(iStringLength)) <> iStringLength THEN\n    RETURN;\nEND_IF;\n\n// Remove ']' first (position iStringLength), then '[' (position 1)\nStrDeleteA(pby := ADR(sWorkingString), iLength := 1, iPosition := iStringLength);\nStrDeleteA(pby := ADR(sWorkingString), iLength := 1, iPosition := 1);\n\n// Trim whitespace just inside the brackets\nStrTrimStartA(ADR(sWorkingString));\nStrTrimEndA(ADR(sWorkingString));\n\n// Empty tuple '[]'\nIF StrLenA(ADR(sWorkingString)) = 0 THEN\n    q_uiSize := 0;\n    RETURN;\nEND_IF;\n\n// Inner string length after bracket removal and trim\niInnerLen := DINT_TO_INT(StrLenA(ADR(sWorkingString)));\n\n// Find first comma position (needed later for element extraction)\niFirstComma := StrFindA(ADR(sWorkingString), ADR(sComma), 1);\n\n// Count top-level commas; elements = commas + 1\nq_uiSize := 1;\nuiFrom := 1;\nREPEAT\n    iCommaPos := StrFindA(ADR(sWorkingString), ADR(sComma), uiFrom);\n    IF iCommaPos > 0 THEN\n        q_uiSize := q_uiSize + 1;\n        uiFrom := INT_TO_UINT(iCommaPos) + 1;\n    END_IF;\nUNTIL iCommaPos <= 0 END_REPEAT;\n\n// Extract the two elements only when exactly 2 are present\nIF q_uiSize = 2 AND iFirstComma > 0 THEN\n\n    // Element 1: copy inner string into q_sLimitMin, then delete comma and everything after\n    q_sLimitMin := sWorkingString;\n    StrDeleteA(pby := ADR(q_sLimitMin), iLength := iInnerLen - iFirstComma + 1, iPosition := iFirstComma);\n    StrTrimA(ADR(q_sLimitMin));\n\t\n    // Element 2: delete first element + comma from sWorkingString, then trim\n    // iFirstComma chars from position 1 = \"10.0,\" → leaves \" 300.0\"\n    StrDeleteA(pby := ADR(sWorkingString), iLength := iFirstComma, iPosition := 1);\n    StrTrimA(ADR(sWorkingString));\n    q_sLimitMax := sWorkingString;\n\t\n\tM_ExtractTargetLimitsFromTuple := TRUE;\n\t\nELSE\n    q_sLimitMin := '';\n    q_sLimitMax := '';\nEND_IF;","LineInfoPersistence":"(string)8b6f68eb-526d-4014-846e-0d34257d4746_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD M_ExtractTargetLimitsFromTuple : BOOL\n(*  Parses a JSON array/tuple expected to hold a target_limits pair, e.g. \"[10.0, 300.0]\" or \"[-12, 12]\".\n    Returns TRUE when the input is a valid JSON array (starts with '[', ends with ']') AND contains 2 top-level elements\n    q_uiSize   : number of top-level elements found.\n    q_sLimitMin: first  element string (trimmed), populated only when q_uiSize = 2.\n    q_sLimitMax: second element string (trimmed), populated only when q_uiSize = 2.\n    If q_uiSize <> 2, q_sLimitMin and q_sLimitMax are cleared to empty strings. *)\nVAR_INPUT\n    /// Data to parse (expected JSON array format, e.g. \"[-12, 12]\")\n    i_sDataToParse : STRING(GPL.Gc_uiMaxSizeMessage);\t\nEND_VAR\nVAR_OUTPUT\n    /// Number of elements found inside the brackets/parentheses\n    q_uiSize    : UINT;\n\t/// target limit min\n    q_sLimitMin : STRING;\n\t/// target limit max\n    q_sLimitMax : STRING;\nEND_VAR\nVAR\n    sWorkingString     : STRING(GPL.Gc_uiMaxSizeMessage);\n    sComma : STRING(1) := ',';\n    sOpenBracket : STRING(1) := '['; // open bracket\n    sCloseBracket : STRING(1) := ']'; // close bracket\n    iStringLength : INT;\n\tiInnerLen : INT;\n   \tiFirstComma : INT;\t\n    iCommaPos : INT;\n    uiFrom : UINT;\nEND_VAR","LineInfoPersistence":"(string)8b6f68eb-526d-4014-846e-0d34257d4746_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}