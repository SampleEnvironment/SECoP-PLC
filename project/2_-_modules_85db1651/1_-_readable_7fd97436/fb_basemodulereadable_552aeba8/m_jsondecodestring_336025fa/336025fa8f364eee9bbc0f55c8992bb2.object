{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)336025fa-8f36-4eee-9bbc-0f55c8992bb2","ParentGuid":"(Guid)552aeba8-69d4-4f40-9593-59848768ad16","Name":"(string)M_JsonDecodeString","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\n// Handle JSON deserialization, double quotes, and escape characters\n\nq_sRawString := '';\nM_JsonDecodeString := FALSE;\n\nIF NOT GVL.G_xJsonLibInstalled THEN // Use String Utils library \n\n\tdiLenW := TO_DINT(StrLenA(ADR(i_sJsonString)));\n\t\n\t// Must start with \" (16#22) and end with \"\n\tpbSrc := ADR(i_sJsonString);\n\tpbDst := ADR(q_sRawString);\n\t\n\tpbTmp := pbSrc;           bChar := pbTmp^;  // first char\n\tIF bChar <> 16#22 THEN RETURN; END_IF\n\tpbTmp := pbSrc + TO_UDINT(diLenW - 1);   bChar := pbTmp^;  // last char\n\tIF bChar <> 16#22 THEN RETURN; END_IF\n\t\n\t// Iterate between quotes, unescape\n\tdiSrc := 1;    // skip opening \"\n\tdiDst := 0;\n\t\n\tWHILE diSrc <= diLenW - 2 DO\n\t\tpbTmp := pbSrc + TO_UDINT(diSrc);\n\t\tbChar := pbTmp^;\n\t\n\t\tIF bChar = 16#5C AND diSrc + 1 <= diLenW - 2 THEN  // backslash\n\t\t\tpbTmp := pbSrc + TO_UDINT(diSrc + 1);\n\t\t\tbNext := pbTmp^;\n\t\t\tCASE bNext OF\n\t\t\t\t16#22: bChar := 16#22;  // \\\" -> \"\n\t\t\t\t16#5C: bChar := 16#5C;  // \\\\ -> \\\n\t\t\t\t16#6E: bChar := 16#0A;  // \\n -> LF\n\t\t\t\t16#72: bChar := 16#0D;  // \\r -> CR\n\t\t\t\t16#74: bChar := 16#09;  // \\t -> TAB\n\t\t\tELSE\n\t\t\t\tbChar := bNext;\n\t\t\tEND_CASE\n\t\t\tdiSrc := diSrc + 2;\n\t\tELSE\n\t\t\tdiSrc := diSrc + 1;\n\t\tEND_IF\n\t\n\t\tpbTmp := pbDst + TO_UDINT(diDst);\n\t\tpbTmp^ := bChar;\n\t\tdiDst := diDst + 1;\n\tEND_WHILE\n\t\n\t// Null terminate\n\tpbTmp := pbDst + TO_UDINT(diDst);\n\tpbTmp^ := 0;\n\t\n\tM_JsonDecodeString := TRUE;\n\nELSE // Use JSON Utilities SL library (license required) \n\t\n\t// Create dedicated JSONData for decode (independent from encode's pJsonData)\n\tIF pJsonDataDec = 0 THEN\n\t\tpJsonDataDec := factoryDec.Create(eError => eErrDec);\n\tEND_IF\n\tIF (pJsonDataDec = 0) OR (eErrDec <> FBF.ERROR.NO_ERROR) THEN\n\t\tRETURN; // out of memory\n\tEND_IF\n\t\n\t// Parse the incoming JSON string\n\t// Wrap in [ ] so the parser accepts it — library requires object/array at root\n\tpJsonDataDec^.Clear();\n\tsTmp := '[';\n\tStrConcatA(pstFrom := ADR(i_sJsonString), pstTo := ADR(sTmp), iBufferSize := SIZEOF(sTmp));\n\tStrConcatA(pstFrom := ADR(']'), pstTo := ADR(sTmp), iBufferSize := SIZEOF(sTmp));\n\twsJsonDec := STRING_TO_WSTRING(sTmp);\n\n\treader(\n\t\txExecute                 := TRUE,\n\t\txAsyncMode               := FALSE,\n\t\txIgnoreValueStringLength := TRUE,\n\t\tpwData                   := ADR(wsJsonDec),\n\t\tjsonData                 := pJsonDataDec^\n\t);\n\t\n\t// Index 0 = array wrapper, index 1 = the string element inside\n\teErrDec := pJsonDataDec^.GetElementByIndex(diIndex := 1, jsonElement => stElement);\n\t\n\tIF eErrDec = FBF.ERROR.NO_ERROR AND stElement.eType = JSON.JSONType.WSTRING_VALUE THEN\n\t\tq_sRawString := WSTRING_TO_STRING(stElement.value.wsValue);\n\t\tM_JsonDecodeString := TRUE;\n\tEND_IF\n\t\n\t// Reset reader\n\treader(xExecute := FALSE, jsonData := pJsonDataDec^);\n\nEND_IF\n","LineInfoPersistence":"(string)336025fa-8f36-4eee-9bbc-0f55c8992bb2_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD M_JsonDecodeString : BOOL\nVAR_INPUT\n    /// JSON-encoded string to decode (e.g. \"hello world\" — with surrounding quotes)\n    i_sJsonString : STRING(GPL.Gc_uiMaxSizeDescription);\nEND_VAR\nVAR_OUTPUT\n    /// Decoded raw PLC string\n    q_sRawString : STRING(GPL.Gc_uiMaxSizeDescription);\nEND_VAR\nVAR\n\tdiSrc  : DINT;\n\tdiDst  : DINT;\n\tpbSrc  : POINTER TO BYTE;\n\tpbDst  : POINTER TO BYTE;\n\tpbTmp  : POINTER TO BYTE;\n\tbChar  : BYTE;\n\tbNext  : BYTE;\n\tsTmp : STRING(GPL.Gc_uiMaxSizeDescription + 2);  // +2 for '[' and ']'\nEND_VAR","LineInfoPersistence":"(string)336025fa-8f36-4eee-9bbc-0f55c8992bb2_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}