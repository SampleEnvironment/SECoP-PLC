{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)c6842e4b-ce22-4957-a5c5-84cdfb06c249","ParentGuid":"(Guid)552aeba8-69d4-4f40-9593-59848768ad16","Name":"(string)M_JsonEncodeString","Properties":{"@Type":"2c41fa04:IDictionary","@Value":[{"@Key":"(Guid)24568a24-c491-472c-a21f-ee5d33859fab","@Value":{"@Type":"24568a24","@Value":{"MemoryReserveForOnlineChange":"(int)0","ExcludeFromBuild":"(bool)False","External":"(bool)False","EnableSystemCall":"(bool)False","CompilerDefines":"(string)","LinkAlways":"(bool)False","Undefines":{"@Type":"[string]","@Value":[]}}}}]},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"24568a24":"{24568a24-c491-472c-a21f-ee5d33859fab}","2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","bool":"System.Boolean","Guid":"System.Guid","int":"System.Int32","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\n// Handle JSON serialization, double quotes, and escape characters\n\nq_sJsonString := '';\nM_JsonEncodeString := FALSE;\n\nIF NOT GVL.G_xJsonLibInstalled THEN // Use String Utils library \n\t\n\tdiLenW := TO_DINT(StrLenA(ADR(i_sRawString)));\n\t\n\tpbSrc := ADR(i_sRawString);\n\tpbDst := ADR(q_sJsonString);\n\t\n\t// Write opening \"\n\tpbTmp  := pbDst;\n\tpbTmp^ := 16#22;\n\tdiDst  := 1;\n\t\n\tdiSrc := 0;\n\tWHILE diSrc <= diLenW - 1 DO\n\t\tpbTmp := pbSrc + TO_UDINT(diSrc);\n\t\tbChar := pbTmp^;\n\t\n\t\t// If the character needs escaping, write the leading \\ and remap bChar\n\t\tIF bChar = 16#22 OR bChar = 16#5C OR bChar = 16#0A OR bChar = 16#0D OR bChar = 16#09 THEN\n\t\t\tpbTmp  := pbDst + TO_UDINT(diDst);\n\t\t\tpbTmp^ := 16#5C;   // backslash prefix\n\t\t\tdiDst  := diDst + 1;\n\t\t\tCASE bChar OF\n\t\t\t\t16#22: bChar := 16#22;  // \" -> \\\"\n\t\t\t\t16#5C: bChar := 16#5C;  // \\ -> \\\\\n\t\t\t\t16#0A: bChar := 16#6E;  // LF  -> \\n\n\t\t\t\t16#0D: bChar := 16#72;  // CR  -> \\r\n\t\t\t\t16#09: bChar := 16#74;  // TAB -> \\t\n\t\t\tEND_CASE\n\t\tEND_IF\n\t\n\t\t// Write character (plain copy or second byte of escape sequence)\n\t\tpbTmp  := pbDst + TO_UDINT(diDst);\n\t\tpbTmp^ := bChar;\n\t\n\t\tdiSrc := diSrc + 1;\n\t\tdiDst := diDst + 1;\n\tEND_WHILE\n\t\n\t// Write closing \"\n\tpbTmp  := pbDst + TO_UDINT(diDst);\n\tpbTmp^ := 16#22;\n\tdiDst  := diDst + 1;\n\t\n\t// Null terminate\n\tpbTmp  := pbDst + TO_UDINT(diDst);\n\tpbTmp^ := 0;\n\t\n\tM_JsonEncodeString := TRUE;\n\t\nELSE // Use JSON Utilities SL library (license required) \n\t\n\t// Create JSON structure in memory: root will be a JSON string (not an array)\n\tIF pJsonData = 0 THEN\n\t\tpJsonData := factory.Create(eError => eErr);\n\tEND_IF\n\tIF (pJsonData = 0) OR (eErr <> FBF.ERROR.NO_ERROR) THEN\n\t\tRETURN; // out of memory\n\tEND_IF;\n\t\n\t// Root = JSON string at index 0, parent = -1 (root)\n\twsRaw := STRING_TO_WSTRING(i_sRawString);\n\tpJsonData^.SetString(wsValue := wsRaw, diIndex := 0, diParentIndex := -1);\n\t\n\t// Serialize synchronously to WSTRING (no BUSY)\n\twsJsonData := \"\"; // clear output buffer\n\twriter(\n\t\txExecute    := TRUE,\n\t\txAsyncMode  := FALSE,             // synchronous: completes in this cycle\n\t\twsLinebreak := \"\",\n\t\tpwData      := ADR(wsJsonData),\n\t\tudiSize     := SIZEOF(wsJsonData),\n\t\tjsonData    := pJsonData^\n\t);\n\t\n\t// Remove trailing \", \" added by JSON writer\n\tdiLenW := StrLenW(ADR(wsJsonData));  // length in wide characters\n\tIF diLenW > 2 THEN\n\t\twsJsonData[diLenW - 2] := 0;  // Terminator in UTF-16\n\t\tq_sJsonString := WSTRING_TO_STRING(wsJsonData);\n\t\tM_JsonEncodeString := TRUE;\n\tELSE\n\t\t// Fallback: empty JSON string literal\n\t\tq_sJsonString := '';\n\tEND_IF\n\t\n\t// reset FB\n\twriter(xExecute := FALSE, jsonData := pJsonData^);\n\nEND_IF\n","LineInfoPersistence":"(string)c6842e4b-ce22-4957-a5c5-84cdfb06c249_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD M_JsonEncodeString : BOOL\nVAR_INPUT\n\t/// Raw PLC string to be JSON-encoded\n\ti_sRawString: STRING(GPL.Gc_uiMaxSizeDescription);\nEND_VAR\nVAR_OUTPUT\n\t/// JSON-encoded string\n\tq_sJsonString: STRING(GPL.Gc_uiMaxSizeDescription);\nEND_VAR\nVAR\n    pbSrc  : POINTER TO BYTE;\n    pbDst  : POINTER TO BYTE;\n    pbTmp  : POINTER TO BYTE;\n    bChar  : BYTE;\n    diLenW : DINT;\n    diSrc  : DINT;\n    diDst  : DINT;\nEND_VAR","LineInfoPersistence":"(string)c6842e4b-ce22-4957-a5c5-84cdfb06c249_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}