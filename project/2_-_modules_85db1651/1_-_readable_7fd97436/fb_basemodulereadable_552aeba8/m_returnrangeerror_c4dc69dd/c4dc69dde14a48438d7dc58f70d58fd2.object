{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)c4dc69dd-e14a-4843-8d7d-c58f70d58fd2","ParentGuid":"(Guid)552aeba8-69d4-4f40-9593-59848768ad16","Name":"(string)M_ReturnRangeError","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)\n// Return \"RangeError\" error\niq_stErrorReport.sClass := 'RangeError';\niq_stErrorReport.sDescription := 'Value must be between ';\nStrConcatA(pstFrom:= ADR(i_RangeMin), pstTo:= ADR(iq_stErrorReport.sDescription), iBufferSize:= UINT_TO_INT(GPL.Gc_uiMaxSizeDescription));\t\nStrConcatA(pstFrom:= ADR(' and '), pstTo:= ADR(iq_stErrorReport.sDescription), iBufferSize:= UINT_TO_INT(GPL.Gc_uiMaxSizeDescription));\t\nStrConcatA(pstFrom:= ADR(i_RangeMax), pstTo:= ADR(iq_stErrorReport.sDescription), iBufferSize:= UINT_TO_INT(GPL.Gc_uiMaxSizeDescription));\t\nM_ReplyWithErrorStraightAway(i_xErrorLatched:= FALSE);\n","LineInfoPersistence":"(string)c4dc69dd-e14a-4843-8d7d-c58f70d58fd2_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD M_ReturnRangeError : BOOL\nVAR_INPUT\n\ti_RangeMin : STRING;\n\ti_RangeMax : STRING;\nEND_VAR\n","LineInfoPersistence":"(string)c4dc69dd-e14a-4843-8d7d-c58f70d58fd2_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"