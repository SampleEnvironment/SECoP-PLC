{"payload":{"meta":{"Graph":{"@Type":"81297157","@Value":{"Guid":"(Guid)80991aa5-7a64-482c-838a-96dc919b59cb","ParentGuid":"(Guid)f4d146d0-ad6c-4d47-9306-631443a136f3","Name":"(string)M_UpdateStatusWhenDriveDone","Properties":{"@Type":"2c41fa04:IDictionary","@Value":{}},"TypeGuid":"(Guid)f8a58466-d7f6-439f-bbb8-d4600e41d099","EmbeddedTypeGuids":{"@Type":"[Guid]","@Value":["(Guid)a9ed5b7e-75c5-4651-af16-d2c27e98cb94","(Guid)3b83b776-fb25-43b8-99f2-3c507c9143fc"]}}},"TypeInfos":{"2c41fa04":"{2c41fa04-1834-41c1-816e-303c7aa2c05b}","81297157":"{81297157-7ec9-45ce-845e-84cab2b88ade}","Guid":"System.Guid","string":"System.String"}},"object":{"Graph":{"@Type":"f8a58466","@Value":{"Implementation":{"@Type":"3b83b776","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)IF i_xDone THEN\n\tIF I_xSpReached THEN // Target reached on time\n\t\tiq_stStatus.etCode := ET_StatusCode.Idle;\n\t\tiq_stStatus.sDescription := 'IDLE';\n\t\tiq_stErrorReport.sClass := '';\n\t\tiq_stErrorReport.sDescription := '';\t\n\tELSIF I_xTimeOutElapsed THEN // Timeout elapsed. Target not reached on time. Build error report\n\t\tiq_stStatus.etCode := ET_StatusCode.Error;\n\t\tiq_stStatus.sDescription := 'Target value not reached on time';\n\t\tiq_stErrorReport.xActive := TRUE;\n\t\tiq_stErrorReport.sClass := 'TimeoutError';\n\t\tiq_stErrorReport.sDescription := 'Target change took longer than the maximum allowed time: ';\n\t\tsTargetDriveTimeout := REAL_TO_STRING(TIME_TO_REAL(iq_stTargetDrive.timTimeout)/1000);\n\t\tStrConcatA(pstFrom:= ADR(sTargetDriveTimeout), pstTo:= ADR(iq_stErrorReport.sDescription), iBufferSize:= UINT_TO_INT(GPL.Gc_uiMaxSizeDescription));\n\t\tStrConcatA(pstFrom:= ADR(' seconds'), pstTo:= ADR(iq_stErrorReport.sDescription), iBufferSize:= UINT_TO_INT(GPL.Gc_uiMaxSizeDescription));\n\tEND_IF\n\tiq_stTargetDrive.uiState := 4;\nEND_IF","LineInfoPersistence":"(string)80991aa5-7a64-482c-838a-96dc919b59cb_Impl_LineIds"}}}},"Interface":{"@Type":"a9ed5b7e","@Value":{"TextDocument":{"@Type":"f3878285","@Value":{"TextBlobForSerialisation":"(string)METHOD M_UpdateStatusWhenDriveDone : BOOL\nVAR_INPUT\n\ti_xDone : BOOL;\n\ti_xSpReached : BOOL;\n\ti_xTimeOutElapsed : BOOL;\t\t\nEND_VAR\nVAR\n\tsTargetDriveTimeout: STRING;\t\nEND_VAR","LineInfoPersistence":"(string)80991aa5-7a64-482c-838a-96dc919b59cb_Decl_LineIds"}}}}}},"TypeInfos":{"3b83b776":"{3b83b776-fb25-43b8-99f2-3c507c9143fc}","a9ed5b7e":"{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}","f3878285":"{f3878285-8e4f-490b-bb1b-9acbb7eb04db}","f8a58466":"{f8a58466-d7f6-439f-bbb8-d4600e41d099}","string":"System.String"}}},"FormatVersion":"1.0"}